<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truco Web</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="game-container">
        <header>
            <h1>Truco</h1>
            <div class="scoreboard">
                <div class="score">Você: <span id="player-score">0</span></div>
                <div class="score">CPU: <span id="cpu-score">0</span></div>
            </div>
        </header>

        <main class="table">
            <div class="hand-area" id="cpu-hand">
                </div>

            <div class="center-area">
                <div class="deck-area">
                    <div class="card back">Maso</div>
                    <div id="vira-card" class="card empty">Vira</div>
                </div>
                <div class="play-area" id="play-area">
                    </div>
            </div>

            <div class="hand-area" id="player-hand">
                </div>
        </main>

        <div class="controls">
            <button id="btn-start" onclick="iniciarRodada()">Nova Rodada</button>
            <button id="btn-truco" disabled>TRUCO!</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
